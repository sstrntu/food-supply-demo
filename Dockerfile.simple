FROM node:20-alpine

WORKDIR /app

# Install dependencies for sqlite3
RUN apk add --no-cache python3 make g++

# Copy backend files
COPY backend/package*.json ./
RUN npm ci

COPY backend/dist ./dist
COPY database ./database

# Copy SSL certs to the location expected by the backend
# Backend looks for ../../key.pem from dist/index.js = /app/key.pem
COPY key.pem cert.pem /app/

EXPOSE 3001

CMD ["node", "dist/index.js"]