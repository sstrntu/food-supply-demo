# Food Supply Voice AI - Environment Configuration
# Copy this file to .env and update with your values

# Server Configuration
NODE_ENV=production
PORT=3001

# Frontend HTTPS Port (single entry point)
FRONTEND_HTTPS_PORT=8443

# Database
DATABASE_PATH=./database/food_supply.db

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Test Credentials (for demo only - remove in production)
TEST_USER_USERNAME=testuser
TEST_USER_PASSWORD=123454321

# ElevenLabs Voice AI
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=agent_7901khz299zdfvcbhtk3c08vcps8

# Anthropic AI (Claude-powered dashboard insights)
ANTHROPIC_API_KEY=

# SSL Certificates (for HTTPS frontend)
SSL_KEY_PATH=./key.pem
SSL_CERT_PATH=./cert.pem

# CORS Origins (comma-separated)
CORS_ORIGINS=https://localhost:8443
